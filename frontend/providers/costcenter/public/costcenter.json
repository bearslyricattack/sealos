{
  "openapi": "3.0.0",
  "info": {
    "title": "App Billing API",
    "description": "API for retrieving application billing and cost information",
    "version": "1.0.0"
  },
  "paths": {
    "/api/app/billing": {
      "post": {
        "summary": "getAppBill",
        "description": "获取应用的费用情况",
        "operationId": "getAppBilling",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "startTime": {
                    "type": "string",
                    "format": "date-time",
                    "description": "Start time for the billing period (ISO format)",
                    "example": "2023-01-01T00:00:00Z"
                  },
                  "endTime": {
                    "type": "string",
                    "format": "date-time",
                    "description": "End time for the billing period (ISO format)",
                    "example": "2023-01-31T23:59:59Z"
                  },
                  "appType": {
                    "type": "string",
                    "description": "Type of the application",
                    "example": "web"
                  },
                  "appName": {
                    "type": "string",
                    "description": "Name of the application",
                    "example": "my-app"
                  },
                  "namespace": {
                    "type": "string",
                    "description": "Kubernetes namespace of the application",
                    "example": "default"
                  },
                  "orderID": {
                    "type": "string",
                    "description": "Order ID for filtering specific orders",
                    "example": "ord-12345"
                  },
                  "page": {
                    "type": "integer",
                    "description": "Page number for pagination",
                    "default": 1,
                    "minimum": 1,
                    "example": 1
                  },
                  "pageSize": {
                    "type": "integer",
                    "description": "Number of items per page",
                    "default": 100,
                    "minimum": 1,
                    "maximum": 1000,
                    "example": 100
                  }
                },
                "required": ["appType", "appName", "namespace"]
              }
            }
          }
        }
      }
    },
    "/api/account/balance": {
      "get": {
        "summary": "getBalance",
        "description": "获取当前的账户余额",
        "operationId": "getUserBalance",
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/api/recharge/discount": {
      "get": {
        "summary": "getRecharge",
        "description": "获取充值优惠信息",
        "operationId": "getRechargeDiscount",
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    }
  }
}
